# Backend Environment Configuration
# Copy this file to .env and update with your values
# DO NOT commit .env to version control

# ==================================================
# APPLICATION SETTINGS
# ==================================================

# Environment: development, staging, production
APP_ENV=production

# Secret key for token signing (change this!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database URL
DATABASE_URL=sqlite:///./test.db

# ==================================================
# EMAIL/SMTP SETTINGS
# ==================================================

# Email provider settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@brainium.local
SMTP_FROM_NAME=Brainium Project Estimation Portal

# Email verification settings
EMAIL_VERIFICATION_CODE_EXPIRY_MINUTES=10
NOTIFICATION_EMAIL_ENABLED=false

# ==================================================
# FRONTEND SETTINGS
# ==================================================

# Frontend URL for CORS and email links
# Local: http://localhost:5173
# Production: https://estimation-calculator.mydevfactory.com
FRONTEND_URL=https://estimation-calculator.mydevfactory.com

# ==================================================
# PRODUCTION DEPLOYMENT
# ==================================================

# Set to "production" to use production CORS domain
ENVIRONMENT=production

# Production domain for CORS whitelist
PRODUCTION_DOMAIN=https://estimation-calculator.mydevfactory.com

# ==================================================
# NOTES
# ==================================================
# - DO NOT commit real secrets to version control
# - Use this file as a template: cp backend/.env.example backend/.env
# - Generate a strong SECRET_KEY for production
# - Get SMTP credentials from your email provider (Gmail, SendGrid, etc.)
# - Set EMAIL_VERIFICATION_CODE_EXPIRY_MINUTES to how long verification codes are valid
# - Set NOTIFICATION_EMAIL_ENABLED to true if you have SMTP configured
